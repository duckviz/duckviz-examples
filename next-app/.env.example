# Copy to `.env.local` and fill in.
#
# Personal access token from https://app.duckviz.com/settings/tokens
# Server-only. Never expose via NEXT_PUBLIC_*.
DUCKVIZ_TOKEN=dvz_live_xxxxxxxxxxxxxxxxxxxxxxxx

# Optional: point the SDK at a non-production DuckViz deployment.
# DUCKVIZ_BASE_URL=https://app.duckviz.com
